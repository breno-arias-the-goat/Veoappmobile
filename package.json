{
  "name": "vilo-teleprompter-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "cross-env EXPO_WEB_DEBUG=true npx tailwindcss -i ./global.css -o ./node_modules/.cache/nativewind/global.css && expo start --web",
    "build": "cross-env NODE_ENV=production npx tailwindcss -i ./global.css -o ./node_modules/.cache/nativewind/global.css && cross-env NODE_ENV=production expo export -p web -c && echo !assets/node_modules/** > dist/.vercelignore && echo !assets/node_modules >> dist/.vercelignore"
  },
  "browser": {
    "react-native-video-processing": false
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/metro-runtime": "~6.1.2",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/slider": "5.0.1",
    "@react-navigation/native": "^7.0.14",
    "@stripe/stripe-react-native": "0.50.3",
    "@tanstack/react-query": "^5.90.21",
    "axios": "^1.13.6",
    "expo": "~54.0.0",
    "expo-audio": "~1.1.1",
    "expo-blur": "~15.0.8",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-linking": "~8.0.11",
    "expo-localization": "^55.0.8",
    "expo-media-library": "~18.2.1",
    "expo-router": "~6.0.23",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-store-review": "~9.0.9",
    "expo-symbols": "~1.0.8",
    "expo-video": "~3.0.16",
    "expo-video-thumbnails": "~10.0.8",
    "expo-web-browser": "~15.0.10",
    "framer-motion": "^12.34.4",
    "i18next": "^25.8.14",
    "nativewind": "^2.0.11",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.71.2",
    "react-i18next": "^16.5.4",
    "react-native": "0.81.5",
    "react-native-fs": "^2.20.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-video-processing": "^1.7.2",
    "react-native-vision-camera": "^4.7.3",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "tailwindcss": "^3.3.2",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "babel-plugin-module-resolver": "^5.0.2",
    "cross-env": "^10.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
